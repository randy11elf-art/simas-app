{
  "expo": {
    "owner": "randy11",
    "name": "SIMAS",
    "slug": "simas-app",
    "newArchEnabled": false,
    "version": "3.4.2",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#6c5ce7",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.simas.mobile",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-screen-orientation",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "bridgeless": false
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3a1d6dee-fb8a-4750-9286-8ce55d03be19"
      }
    }
  }
}